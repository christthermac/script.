def extract_pdf_tables(input_path: Path, out_dir: Path) -> list[TableRecord]:
    records = []

    if input_path.suffix.lower() != ".pdf":
        return records

    if pdfplumber is None:
        print("Table extraction skipped: pdfplumber is not installed.")
        return records

    tables_dir = out_dir / "tables"
    ensure_dir(tables_dir)

    excel_file = tables_dir / "all_tables.xlsx"

    with pdfplumber.open(str(input_path)) as pdf, pd.ExcelWriter(excel_file, engine="openpyxl") as writer:
        for page_number, page in enumerate(tqdm(pdf.pages, desc="Extracting tables"), start=1):
            try:
                tables = page.extract_tables() or []
            except Exception as e:
                write_text(out_dir / "logs" / "table_errors.log", f"Page {page_number}: {e}\\n")
                continue

            for table_number, table in enumerate(tables, start=1):
                if not table:
                    continue

                df = pd.DataFrame(table)
                csv_file = tables_dir / f"page_{page_number:04d}_table_{table_number:04d}.csv"
                df.to_csv(csv_file, index=False, header=False)

                sheet = f"p{page_number:04d}_t{table_number:02d}"[:31]
                df.to_excel(writer, index=False, header=False, sheet_name=sheet)

                records.append(TableRecord(
                    page_number=page_number,
                    table_number=table_number,
                    csv_file=str(csv_file.relative_to(out_dir)),
                    rows=int(df.shape[0]),
                    cols=int(df.shape[1]),
                    source="pdfplumber",
                ))

    return records

