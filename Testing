def extract_pdf_native_text(input_path: Path, out_dir: Path) -> tuple[str, list[TextRecord]]:
    if input_path.suffix.lower() != ".pdf":
        return "", []

    doc = fitz.open(str(input_path))
    all_text_parts = []
    records = []

    for page_number, page in enumerate(tqdm(doc, desc="Extracting native PDF text"), start=1):
        text = clean_text(page.get_text("text"))
        text_file = out_dir / "texts" / "native_pages" / f"page_{page_number:04d}.txt"
        write_text(text_file, text)

        all_text_parts.append(f"\\n\\n===== PAGE {page_number} =====\\n\\n{text}")

        records.append(TextRecord(
            page_number=page_number,
            native_text_file=str(text_file.relative_to(out_dir)),
            ocr_text_file=None,
            native_word_count=len(text.split()),
            ocr_word_count=0,
        ))

    full_text = clean_text("".join(all_text_parts))
    write_text(out_dir / "texts" / "native_full_text.txt", full_text)

    return full_text, records

def ocr_page_image(image_path: Path, lang: str = "eng", psm: int = 6) -> tuple[str, list[dict]]:
    if pytesseract is None or not command_exists("tesseract"):
        return "", []

    try:
        image = Image.open(image_path)
        config = f"--psm {psm}"
        text = clean_text(pytesseract.image_to_string(image, lang=lang, config=config))

        data = pytesseract.image_to_data(
            image,
            lang=lang,
            config=config,
            output_type=pytesseract.Output.DICT
        )

        words = []
        for i, word in enumerate(data.get("text", [])):
            word = str(word).strip()
            if not word:
                continue
            words.append({
                "text": word,
                "conf": data["conf"][i],
                "x": data["left"][i],
                "y": data["top"][i],
                "w": data["width"][i],
                "h": data["height"][i],
            })

        return text, words

    except Exception as e:
        return f"[OCR_ERROR] {e}", []

def run_ocr_on_pages(
    pages: list[LoadedPage],
    out_dir: Path,
    ocr_lang: str = "eng",
    psm: int = 6
) -> list[TextRecord]:
    records = []

    if not has_tesseract():
        print("OCR skipped: Tesseract is not installed or not in PATH.")
        return records

    for page in tqdm(pages, desc="Running OCR on normalized pages"):
        image_path = out_dir / page.normalized_image
        text, words = ocr_page_image(image_path, lang=ocr_lang, psm=psm)

        text_file = out_dir / "texts" / "ocr_pages" / f"page_{page.page_number:04d}_ocr.txt"
        json_file = out_dir / "texts" / "ocr_pages" / f"page_{page.page_number:04d}_ocr_words.json"

        write_text(text_file, text)
        write_json(json_file, words)

        records.append(TextRecord(
            page_number=page.page_number,
            native_text_file=None,
            ocr_text_file=str(text_file.relative_to(out_dir)),
            native_word_count=0,
            ocr_word_count=len(text.split()),
        ))

    # combined OCR full text
    combined = []
    for rec in records:
        if rec.ocr_text_file:
            p = out_dir / rec.ocr_text_file
            combined.append(f"\\n\\n===== PAGE {rec.page_number} OCR =====\\n\\n{p.read_text(encoding='utf-8', errors='replace')}")
    write_text(out_dir / "texts" / "ocr_full_text.txt", clean_text("".join(combined)))

    return records

