def extract_pdf_embedded_images(input_path: Path, out_dir: Path) -> list[ImageRecord]:
    if input_path.suffix.lower() != ".pdf":
        return []

    doc = fitz.open(str(input_path))
    records = []

    for page_number, page in enumerate(tqdm(doc, desc="Extracting embedded PDF images"), start=1):
        images = page.get_images(full=True) or []

        for image_number, img in enumerate(images, start=1):
            xref = img[0]
            try:
                extracted = doc.extract_image(xref)
                ext = extracted.get("ext", "png")
                width = int(extracted.get("width", 0))
                height = int(extracted.get("height", 0))

                image_file = out_dir / "images" / "embedded_original" / f"page_{page_number:04d}_image_{image_number:04d}.{ext}"
                ensure_dir(image_file.parent)
                image_file.write_bytes(extracted["image"])

                bbox = None
                try:
                    rects = page.get_image_rects(xref)
                    if rects:
                        r = rects[0]
                        bbox = [float(r.x0), float(r.y0), float(r.x1), float(r.y1)]
                except Exception:
                    pass

                records.append(ImageRecord(
                    page_number=page_number,
                    image_number=image_number,
                    image_file=str(image_file.relative_to(out_dir)),
                    width=width,
                    height=height,
                    extension=ext,
                    source="pdf_embedded",
                    bbox=bbox,
                ))

            except Exception as e:
                write_text(out_dir / "logs" / "embedded_image_errors.log", f"Page {page_number}, image {image_number}: {e}\\n")

    return records

def register_page_images(pages: list[LoadedPage], out_dir: Path) -> list[ImageRecord]:
    records = []
    for page in pages:
        for source, rel_path in [("rendered_page", page.original_image), ("normalized_page", page.normalized_image)]:
            image_path = out_dir / rel_path
            if not image_path.exists():
                continue
            with Image.open(image_path) as im:
                width, height = im.size
            records.append(ImageRecord(
                page_number=page.page_number,
                image_number=0,
                image_file=rel_path,
                width=width,
                height=height,
                extension=image_path.suffix.lower().replace(".", ""),
                source=source,
                bbox=None,
            ))
    return records
