2. Universal document loader
The loader auto-detects PDF, image, TIFF multi-page, SVG inputs and converts them into normalized page images.
================================================================================================================

class UniversalDocumentLoader:
    def __init__(self, out_dir: Path, dpi: int = 300):
        self.out_dir = Path(out_dir)
        self.dpi = dpi

    def load(self, input_path: str | Path) -> tuple[list[LoadedPage], dict]:
        input_path = Path(input_path)
        ext = input_path.suffix.lower()

        if ext not in SUPPORTED_INPUTS:
            raise ValueError(f"Unsupported file type: {ext}. Supported: {sorted(SUPPORTED_INPUTS)}")

        if ext == ".pdf":
            return self.load_pdf(input_path)
        if ext == ".svg":
            return self.load_svg(input_path)
        return self.load_image(input_path)

    def load_pdf(self, pdf_path: Path) -> tuple[list[LoadedPage], dict]:
        doc = fitz.open(str(pdf_path))
        pages = []

        original_dir = self.out_dir / "loader" / "original_pages"
        normalized_dir = self.out_dir / "loader" / "normalized_pages"

        zoom = self.dpi / 72.0
        matrix = fitz.Matrix(zoom, zoom)

        for page_number, page in enumerate(tqdm(doc, desc="Loading PDF pages"), start=1):
            pix = page.get_pixmap(matrix=matrix, alpha=False)

            original = original_dir / f"page_{page_number:04d}.png"
            normalized = normalized_dir / f"page_{page_number:04d}_normalized.png"
            ensure_dir(original.parent)

            pix.save(str(original))
            normalize_layout(original, normalized)

            with Image.open(normalized) as im:
                width, height = im.size

            pages.append(LoadedPage(
                page_number=page_number,
                source_type="pdf_page",
                original_image=str(original.relative_to(self.out_dir)),
                normalized_image=str(normalized.relative_to(self.out_dir)),
                width=width,
                height=height,
            ))

        return pages, {
            "input_type": "pdf",
            "page_count": doc.page_count,
            "pdf_metadata": dict(doc.metadata or {}),
        }

    def load_image(self, image_path: Path) -> tuple[list[LoadedPage], dict]:
        img = Image.open(image_path)

        # TIFF can contain multiple pages/frames
        frames = list(ImageSequence.Iterator(img)) if image_path.suffix.lower() in [".tif", ".tiff"] else [img]
        pages = []

        original_dir = self.out_dir / "loader" / "original_pages"
        normalized_dir = self.out_dir / "loader" / "normalized_pages"

        for page_number, frame in enumerate(tqdm(frames, desc="Loading image frames"), start=1):
            original = original_dir / f"page_{page_number:04d}.png"
            normalized = normalized_dir / f"page_{page_number:04d}_normalized.png"
            ensure_dir(original.parent)

            frame.convert("RGB").save(original)
            normalize_layout(original, normalized)

            with Image.open(normalized) as im:
                width, height = im.size

            pages.append(LoadedPage(
                page_number=page_number,
                source_type="image",
                original_image=str(original.relative_to(self.out_dir)),
                normalized_image=str(normalized.relative_to(self.out_dir)),
                width=width,
                height=height,
            ))

        return pages, {
            "input_type": "image",
            "frame_count": len(frames),
            "format": img.format,
        }

    def load_svg(self, svg_path: Path) -> tuple[list[LoadedPage], dict]:
        svg_dir = self.out_dir / "svg"
        ensure_dir(svg_dir)

        svg_text = svg_path.read_text(encoding="utf-8", errors="replace")
        write_text(svg_dir / "raw_svg.xml", svg_text)

        svg_text_records = extract_svg_text(svg_path)
        write_json(svg_dir / "svg_text_elements.json", svg_text_records)
        write_text(svg_dir / "svg_text_content.txt", "\\n".join([x.get("text", "") for x in svg_text_records]))

        original = self.out_dir / "loader" / "original_pages" / "page_0001.png"
        normalized = self.out_dir / "loader" / "normalized_pages" / "page_0001_normalized.png"

        rasterized = False
        try:
            import cairosvg
            ensure_dir(original.parent)
            cairosvg.svg2png(url=str(svg_path), write_to=str(original), dpi=self.dpi)
            normalize_layout(original, normalized)
            rasterized = True
        except Exception as e:
            write_text(self.out_dir / "logs" / "svg_rasterization_error.txt", str(e))

        pages = []
        if rasterized:
            with Image.open(normalized) as im:
                width, height = im.size

            pages.append(LoadedPage(
                page_number=1,
                source_type="svg_rasterized",
                original_image=str(original.relative_to(self.out_dir)),
                normalized_image=str(normalized.relative_to(self.out_dir)),
                width=width,
                height=height,
            ))

        return pages, {
            "input_type": "svg",
            "svg_text_element_count": len(svg_text_records),
            "svg_rasterized": rasterized,
        }

def extract_svg_text(svg_path: Path) -> list[dict]:
    records = []
    try:
        tree = ET.parse(svg_path)
        root = tree.getroot()
        for elem in root.iter():
            tag = elem.tag.split("}")[-1]
            if tag in ["text", "tspan"]:
                text = "".join(elem.itertext()).strip()
                if text:
                    records.append({
                        "tag": tag,
                        "text": text,
                        "attributes": dict(elem.attrib),
                    })
    except Exception as e:
        records.append({"error": str(e)})
    return records

