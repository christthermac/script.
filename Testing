8. Master extraction function
Function to run.

=======================================================================================================
def run_full_extraction(
    input_file: str,
    output_folder: str = "extracted_output",
    dpi: int = 300,
    run_ocr: bool = True,
    ocr_lang: str = "eng",
    tesseract_psm: int = 6,
) -> dict:
    input_path = Path(input_file).resolve()
    out_dir = Path(output_folder).resolve()

    if not input_path.exists():
        raise FileNotFoundError(f"Input file not found: {input_path}")

    ensure_dir(out_dir)

    metadata = {
        "input_file": str(input_path),
        "file_name": input_path.name,
        "file_type": input_path.suffix.lower(),
        "file_size_bytes": input_path.stat().st_size,
        "extracted_at_utc": datetime.utcnow().isoformat() + "Z",
        "pipeline": "Geological Extractor - charts, tables, images, texts",
    }

    # 1. Load and normalize pages
    loader = UniversalDocumentLoader(out_dir=out_dir, dpi=dpi)
    pages, loader_metadata = loader.load(input_path)
    metadata.update(loader_metadata)

    # 2. Native PDF text extraction with PyMuPDF
    native_full_text, native_text_records = extract_pdf_native_text(input_path, out_dir)

    # 3. OCR extraction
    ocr_text_records = []
    if run_ocr:
        ocr_text_records = run_ocr_on_pages(
            pages=pages,
            out_dir=out_dir,
            ocr_lang=ocr_lang,
            psm=tesseract_psm
        )

    text_records = native_text_records + ocr_text_records

    # 4. Image extraction
    page_image_records = register_page_images(pages, out_dir)
    embedded_image_records = extract_pdf_embedded_images(input_path, out_dir)
    image_records = page_image_records + embedded_image_records

    # 5. Ordinary PDF table extraction
    table_records = extract_pdf_tables(input_path, out_dir)

    # 6. Chart detection
    chart_records = detect_chart_candidates(pages, out_dir)

    # 7. Save everything as JSON and Excel
    saved = save_outputs(
        out_dir=out_dir,
        metadata=metadata,
        pages=pages,
        text_records=text_records,
        image_records=image_records,
        table_records=table_records,
        chart_records=chart_records,
    )

    results = {
        "output_folder": str(out_dir),
        "pages": len(pages),
        "texts": len(text_records),
        "images": len(image_records),
        "tables": len(table_records),
        "charts": len(chart_records),
        **saved,
    }

    print("\\nDONE. Extraction completed.")
    for k, v in results.items():
        print(f"{k}: {v}")

    return results

