6. Chart / figure detection
This detects and crops likely chart regions using OpenCV line/edge density.
===================================================================================================================

def detect_chart_candidates(pages: list[LoadedPage], out_dir: Path) -> list[ChartRecord]:
    records = []

    for page in tqdm(pages, desc="Detecting chart candidates"):
        image_path = out_dir / page.normalized_image
        img = cv2.imread(str(image_path))
        if img is None:
            continue

        gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

        # Detect line-heavy/box-heavy regions, useful for charts, diagrams, tables, columns.
        edges = cv2.Canny(gray, 50, 150)
        kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (7, 7))
        closed = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel)

        contours, _ = cv2.findContours(closed, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

        h, w = gray.shape[:2]
        page_area = w * h
        candidates = []

        for cnt in contours:
            x, y, bw, bh = cv2.boundingRect(cnt)
            area = bw * bh

            if area < page_area * 0.025:
                continue
            if bw < 120 or bh < 80:
                continue

            aspect = bw / max(bh, 1)
            if aspect < 0.12 or aspect > 10:
                continue

            candidates.append((x, y, bw, bh, area))

        # Largest candidates first
        candidates = sorted(candidates, key=lambda z: z[4], reverse=True)[:10]

        for chart_number, (x, y, bw, bh, area) in enumerate(candidates, start=1):
            crop = img[y:y+bh, x:x+bw]
            crop_file = out_dir / "charts" / "candidates" / f"page_{page.page_number:04d}_chart_{chart_number:04d}.png"
            ensure_dir(crop_file.parent)
            cv2.imwrite(str(crop_file), crop)

            records.append(ChartRecord(
                page_number=page.page_number,
                chart_number=chart_number,
                crop_file=str(crop_file.relative_to(out_dir)),
                bbox=[int(x), int(y), int(x + bw), int(y + bh)],
                reason="large_line_or_edge_dense_region",
            ))

    return records
