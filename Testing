1. Layout normalization
This stage improves OCR and chart detection by denoising, deskewing, sharpening, contrast enhancement, and margin cleanup.

============================================================================================================================
def deskew_image_cv(img: np.ndarray) -> np.ndarray:
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    inverted = cv2.bitwise_not(gray)
    thresh = cv2.threshold(inverted, 0, 255, cv2.THRESH_BINARY | cv2.THRESH_OTSU)[1]

    coords = np.column_stack(np.where(thresh > 0))
    if coords.size < 100:
        return img

    angle = cv2.minAreaRect(coords)[-1]
    if angle < -45:
        angle = -(90 + angle)
    else:
        angle = -angle

    # Avoid aggressive wrong rotation
    if abs(angle) < 0.1 or abs(angle) > 10:
        return img

    h, w = img.shape[:2]
    center = (w // 2, h // 2)
    matrix = cv2.getRotationMatrix2D(center, angle, 1.0)
    return cv2.warpAffine(
        img, matrix, (w, h),
        flags=cv2.INTER_CUBIC,
        borderMode=cv2.BORDER_REPLICATE
    )

def normalize_layout(
    input_image: Path,
    output_image: Path,
    denoise: bool = True,
    deskew: bool = True,
    contrast: bool = True,
    sharpen: bool = True,
    margin_cleanup: bool = True,
    max_dim: int = 3500,
) -> None:
    ensure_dir(output_image.parent)

    pil_img = Image.open(input_image).convert("RGB")
    w, h = pil_img.size
    largest = max(w, h)

    # Keep images manageable for OCR but preserve detail
    if largest > max_dim:
        scale = max_dim / largest
        pil_img = pil_img.resize((int(w * scale), int(h * scale)), Image.LANCZOS)

    img = pil_to_cv(pil_img)

    if margin_cleanup:
        img = cv2.copyMakeBorder(
            img, 20, 20, 20, 20,
            cv2.BORDER_CONSTANT,
            value=[255, 255, 255]
        )

    if denoise:
        img = cv2.fastNlMeansDenoisingColored(img, None, 5, 5, 7, 21)

    if contrast:
        lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
        l, a, b = cv2.split(lab)
        clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
        cl = clahe.apply(l)
        img = cv2.cvtColor(cv2.merge((cl, a, b)), cv2.COLOR_LAB2BGR)

    if deskew:
        img = deskew_image_cv(img)

    if sharpen:
        kernel = np.array([[0, -1, 0],
                           [-1, 5, -1],
                           [0, -1, 0]])
        img = cv2.filter2D(img, -1, kernel)

    cv2.imwrite(str(output_image), img)
