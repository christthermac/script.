def make_summary_safe_df(records):
    """
    Convert records into a DataFrame that is safe for Excel export.
    Nested objects such as dict/list/tuple/set and NumPy objects are serialized.
    """
    df = pd.DataFrame(records)

    def safe_value(x):
        if isinstance(x, (dict, list, tuple, set)):
            return json.dumps(x, ensure_ascii=False)
        if isinstance(x, np.ndarray):
            return json.dumps(x.tolist(), ensure_ascii=False)
        if isinstance(x, (np.integer,)):
            return int(x)
        if isinstance(x, (np.floating,)):
            return float(x)
        if isinstance(x, (np.bool_,)):
            return bool(x)
        return x

    for col in df.columns:
        df[col] = df[col].apply(safe_value)

    return df


def save_outputs(
    out_dir: Path,
    metadata: dict,
    pages: list[LoadedPage],
    text_records: list[TextRecord],
    image_records: list[ImageRecord],
    table_records: list[TableRecord],
    chart_records: list[ChartRecord],
) -> dict:
    ensure_dir(out_dir / "metadata")
    ensure_dir(out_dir / "summary")

    # Save JSON metadata
    write_json(out_dir / "metadata" / "metadata.json", metadata)
    write_json(out_dir / "metadata" / "pages.json", [asdict(x) for x in pages])
    write_json(out_dir / "metadata" / "texts.json", [asdict(x) for x in text_records])
    write_json(out_dir / "metadata" / "images.json", [asdict(x) for x in image_records])
    write_json(out_dir / "metadata" / "tables.json", [asdict(x) for x in table_records])
    write_json(out_dir / "metadata" / "charts.json", [asdict(x) for x in chart_records])

    # Excel summary
    excel_path = out_dir / "summary" / "extraction_summary.xlsx"

    with pd.ExcelWriter(excel_path, engine="openpyxl") as writer:
        make_summary_safe_df([metadata]).to_excel(
            writer, sheet_name="metadata", index=False
        )

        make_summary_safe_df([asdict(x) for x in pages]).to_excel(
            writer, sheet_name="pages", index=False
        )

        make_summary_safe_df([asdict(x) for x in text_records]).to_excel(
            writer, sheet_name="texts", index=False
        )

        make_summary_safe_df([asdict(x) for x in image_records]).to_excel(
            writer, sheet_name="images", index=False
        )

